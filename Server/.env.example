PORT=5000
MAX_FILE_SIZE_MB=60
SESSION_TTL_FILE_MIN=7
SESSION_TTL_MESSAGE_MIN=5

# Set to "production" on your deployment platform
NODE_ENV=development

# In production, set this to your deployed frontend URL (e.g. https://ephemeraldrop.vercel.app)
# In development, leave it blank — the server dynamically uses the request origin
CLIENT_ORIGIN=

# ── Cloudinary ──────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=ephemeraldrop
