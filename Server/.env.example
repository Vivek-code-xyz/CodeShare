# ── Server Environment Variables (set these on Render dashboard) ──

# Render assigns PORT automatically — do NOT set it manually
# PORT=

NODE_ENV=production
MAX_FILE_SIZE_MB=60
SESSION_TTL_FILE_MIN=7
SESSION_TTL_MESSAGE_MIN=5

# Your Vercel frontend URL (for CORS and share link generation)
CLIENT_ORIGIN=https://code-share-beryl.vercel.app

# ── Cloudinary ──────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=ephemeraldrop
