PORT                    =
MAX_FILE_SIZE_MB        = 60
SESSION_TTL_FILE_MIN    = 7
SESSION_TTL_MESSAGE_MIN = 5

# Set to "production" on your deployment platform
NODE_ENV                = production

# In production, set this to your deployed frontend URL (e.g. https://ephemeraldrop.vercel.app)
CLIENT_ORIGIN           = https://your-frontend.vercel.app

# ── Upstash Redis (required for Vercel/serverless — get free at upstash.com) ──
UPSTASH_REDIS_REST_URL   = https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN = your_token_here

# ── Cloudinary ──────────────────────────────────
CLOUDINARY_CLOUD_NAME   = your_cloud_name
CLOUDINARY_API_KEY      = your_api_key
CLOUDINARY_API_SECRET   = your_api_secret
CLOUDINARY_FOLDER       = ephemeraldrop
